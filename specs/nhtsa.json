{
  "openapi": "3.0.3",
  "info": {
    "title": "NHTSA Vehicle API",
    "description": "National Highway Traffic Safety Administration vehicle identification number (VIN) decoding API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://vpic.nhtsa.dot.gov/api"
    }
  ],
  "paths": {
    "/vehicles/DecodeVinValuesBatch/": {
      "post": {
        "operationId": "decodeVinBatch",
        "summary": "Decode a batch of VINs",
        "tags": ["Vehicles"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["vins"],
                "properties": {
                  "vins": {
                    "type": "string",
                    "description": "VINs separated by semicolons"
                  },
                  "format": {
                    "type": "string",
                    "default": "json",
                    "description": "Response format"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with decoded VIN results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Results": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
