{
  "openapi": "3.0.3",
  "info": {
    "title": "PubMed Central (PMC) E-Utilities API",
    "description": "Search PubMed Central open-access biomedical and life sciences literature",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://eutils.ncbi.nlm.nih.gov"
    }
  ],
  "paths": {
    "/entrez/eutils/esearch.fcgi": {
      "get": {
        "operationId": "searchPMC",
        "summary": "Search PubMed Central articles",
        "tags": ["PMC"],
        "parameters": [
          {
            "name": "term",
            "in": "query",
            "required": true,
            "description": "Search query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "db",
            "in": "query",
            "required": false,
            "description": "Database to search",
            "schema": {
              "type": "string",
              "default": "pmc"
            }
          },
          {
            "name": "retmax",
            "in": "query",
            "required": false,
            "description": "Maximum number of results to return",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "retmode",
            "in": "query",
            "required": false,
            "description": "Return format",
            "schema": {
              "type": "string",
              "default": "json"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "Sort order",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}
