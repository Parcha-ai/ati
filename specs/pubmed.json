{
  "openapi": "3.0.3",
  "info": {
    "title": "PubMed E-Utilities API",
    "description": "Search PubMed biomedical literature via NCBI E-Utilities",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils"
    }
  ],
  "paths": {
    "/esearch.fcgi": {
      "get": {
        "operationId": "searchPubmed",
        "summary": "Search PubMed articles",
        "tags": ["PubMed"],
        "parameters": [
          {
            "name": "term",
            "in": "query",
            "required": true,
            "description": "Search term",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "retmax",
            "in": "query",
            "required": false,
            "description": "Maximum number of results to return",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "db",
            "in": "query",
            "required": false,
            "description": "Database to search",
            "schema": {
              "type": "string",
              "default": "pubmed"
            }
          },
          {
            "name": "retmode",
            "in": "query",
            "required": false,
            "description": "Return mode",
            "schema": {
              "type": "string",
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "esearchresult": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
