{
  "openapi": "3.0.3",
  "info": {
    "title": "Amadeus Travel API",
    "description": "Amadeus self-service API for flight offers and travel data",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://test.api.amadeus.com"
    }
  ],
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://test.api.amadeus.com/v1/security/oauth2/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/v2/shopping/flight-offers": {
      "get": {
        "operationId": "searchFlightOffers",
        "summary": "Search for flight offers",
        "tags": ["Flights"],
        "parameters": [
          {
            "name": "originLocationCode",
            "in": "query",
            "required": true,
            "description": "Origin IATA airport code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "destinationLocationCode",
            "in": "query",
            "required": true,
            "description": "Destination IATA airport code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "departureDate",
            "in": "query",
            "required": true,
            "description": "Departure date in YYYY-MM-DD format",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "returnDate",
            "in": "query",
            "required": false,
            "description": "Return date in YYYY-MM-DD format",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "adults",
            "in": "query",
            "required": true,
            "description": "Number of adult passengers",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "travelClass",
            "in": "query",
            "required": false,
            "description": "Travel class",
            "schema": {
              "type": "string",
              "enum": ["ECONOMY", "PREMIUM_ECONOMY", "BUSINESS", "FIRST"]
            }
          },
          {
            "name": "max",
            "in": "query",
            "required": false,
            "description": "Maximum number of results",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with flight offers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}
