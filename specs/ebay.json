{
  "openapi": "3.0.3",
  "info": {
    "title": "eBay Browse API",
    "description": "Search and browse eBay listings",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.ebay.com"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/buy/browse/v1/item_summary/search": {
      "get": {
        "operationId": "searchItems",
        "summary": "Search eBay item listings",
        "tags": ["Browse"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search keywords",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category_ids",
            "in": "query",
            "required": false,
            "description": "Category IDs to filter by",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Results per page",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Pagination offset",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "description": "Additional filters",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "Sort order",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with item summaries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}
