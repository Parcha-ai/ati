    "/propertyapi/v1.0.0/property/address": {
      "get": {
        "operationId": "propertyAddress",
        "summary": "Search properties by area \u2014 ZIP code, radius, or coordinates. Returns address list with attomIds.",
        "tags": [
          "Property"
        ],
        "parameters": [
          {
            "name": "postalcode",
            "in": "query",
            "description": "5-digit US ZIP code for area searches",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "latitude",
            "in": "query",
            "description": "Center latitude for radius search",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "longitude",
            "in": "query",
            "description": "Center longitude for radius search",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "description": "Radius in miles for geographic search",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "minbeds",
            "in": "query",
            "description": "Minimum bedrooms",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "maxbeds",
            "in": "query",
            "description": "Maximum bedrooms",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "minyearbuilt",
            "in": "query",
            "description": "Minimum year built",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "maxyearbuilt",
            "in": "query",
            "description": "Maximum year built",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "minuniversalsize",
            "in": "query",
            "description": "Minimum building square footage",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "maxuniversalsize",
            "in": "query",
            "description": "Maximum building square footage",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number (default 1)",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pagesize",
            "in": "query",
            "description": "Results per page (default 10, max 10000)",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "orderby",
            "in": "query",
            "description": "Sort field with direction (e.g. 'saleamt+desc')",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
