    "/propertyapi/v1.0.0/property/detail": {
      "get": {
        "operationId": "propertyDetail",
        "summary": "Property characteristics \u2014 lot size, building details, utilities. Query first for foundational data.",
        "tags": [
          "Property"
        ],
        "parameters": [
          {
            "name": "address1",
            "in": "query",
            "description": "Street address (e.g. '216 Encounter Bay')",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "address2",
            "in": "query",
            "description": "City, state, and ZIP (e.g. 'Alameda, CA 94502')",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attomid",
            "in": "query",
            "description": "ATTOM property identifier (from any prior response)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
