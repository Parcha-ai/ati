{
  "openapi": "3.0.3",
  "info": {
    "title": "ATTOM Property Data API",
    "description": "ATTOM property data for 155M+ US properties \u2014 ownership, tax assessments, sales history, mortgages, valuations, rental AVMs, and building details.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.gateway.attomdata.com"
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "apikey"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
