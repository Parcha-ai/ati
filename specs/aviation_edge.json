{
  "openapi": "3.0.3",
  "info": {
    "title": "Aviation Edge API",
    "description": "Real-time and historical aviation data including flight tracking",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://aviation-edge.com"
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/v2/public/flights": {
      "get": {
        "operationId": "searchFlights",
        "summary": "Search for flights",
        "tags": ["Aviation"],
        "parameters": [
          {
            "name": "flight_iata",
            "in": "query",
            "required": false,
            "description": "IATA flight number",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "airline_iata",
            "in": "query",
            "required": false,
            "description": "IATA airline code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dep_iata",
            "in": "query",
            "required": false,
            "description": "Departure airport IATA code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "arr_iata",
            "in": "query",
            "required": false,
            "description": "Arrival airport IATA code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with flight data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
